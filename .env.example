# Copy to .env and fill in real values. Do not commit .env.
# Local dev defaults to dev Supabase. See docs/DEV_PROD_ENVIRONMENTS.md.

# Supabase Configuration (dev by default)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# Superwall Configuration (one key shared dev/prod — sandbox handles isolation)
SUPERWALL_API_KEY=pk_...

# Paywall Testing
# "true" to skip paywall in dev, "false" to test paywall
SKIP_PAYWALL=false

# PostHog Analytics
# Get project token from PostHog dashboard → Project Settings → Project API Keys
POSTHOG_PROJECT_TOKEN=phc_...
POSTHOG_HOST=https://us.i.posthog.com
