# Expo
.expo/
dist/
web-build/

# dependencies
node_modules/

# Environment variables — catch-all so NO secret env file can ever be committed.
# The individual-line list (.env, .env.local, .env.*.local, .env.prod) missed
# real filenames the workflow creates — notably `.env.dev.bak`, which the
# src/lib/supabase.ts dev→prod guard instructs you to make as a copy of
# `.env.prod` (i.e. it holds the prod DB password). One `git add -A` would have
# committed it. Catch-all `.env*` + an allowlist for the committed template.
.env*
!.env.example

# Expo
__generated__

# macOS
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.orig.*
*.~*

# Supabase CLI local state (which project you're linked to, cached versions, etc.)
supabase/.temp/

# Local DB backups produced by scripts/backup-prod.sh — real prod schema+data
# dumps. Never commit these (they contain user data and bloat the repo).
backups/

# Claude Code local settings + skills (per-machine, do not commit)
.claude/

# Native folders — regenerated by `expo prebuild --clean` on every build.
# All native config lives in app.config.js. See docs/DEV_PROD_ENVIRONMENTS.md.
ios/
android/
