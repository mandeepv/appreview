{
  "expo": {
    "name": "Kinderwell",
    "slug": "kinderwell",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F8F8B"
    },
    "icon": "./assets/icon.png",
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#4F8F8B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kinderwell.app",
      "buildNumber": "7",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.kinderwell.app"
            ]
          }
        ]
      },
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:REDACTED_PROD_SUPABASE_PROJECT_REF.supabase.co"
      ]
    },
    "android": {
      "package": "com.kinderwell.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "REDACTED_PROD_SUPABASE_PROJECT_REF.supabase.co"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "scheme": "kinderwell",
    "plugins": [
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#4F8F8B"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "privacy": "public",
    "extra": {
      "eas": {
        "projectId": "e663a1d9-f73c-414f-8e61-de69e013c972"
      }
    }
  }
}
